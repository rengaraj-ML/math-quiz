{
  "name": "math-quiz-mcp-app",
  "version": "1.0.0",
  "description": "MCP App for 6th grade math quiz - embedded UI in Claude.ai",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "math-quiz-mcp": "dist/main.js"
  },
  "scripts": {
    "build": "npm run build:ui && npm run build:server && npm run build:index",
    "build:ui": "cross-env INPUT=mcp-app.html vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:index": "tsc -p tsconfig.index.json",
    "dev": "cross-env NODE_ENV=development concurrently \"npm run watch\" \"npm run serve\"",
    "watch": "cross-env INPUT=mcp-app.html vite build --watch",
    "serve": "tsx main.ts",
    "start": "node dist/main.js",
    "start:stdio": "node dist/main.js --stdio"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
